    <bpmn:sequenceFlow id="Flow_1waftpa" sourceRef="StartEvent_1" targetRef="Activity_019gubg" />
    <bpmn:serviceTask id="Activity_019gubg" name="Initiale Anfrage" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:documentation />
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.E2E_SMTP_USERNAME}}" target="authentication.username" />
          <zeebe:input source="{{secrets.E2E_SMTP_PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="{{secrets.E2E_SMTP_SERVER}}" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="{{secrets.E2E_SMTP_PORT}}" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="NONE" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.E2E_SMTP_USERNAME}}" target="data.smtpAction.from" />
          <zeebe:input source="{{secrets.INBOUND_IMAP_USERNAME}}" target="data.smtpAction.to" />
          <zeebe:input source="Eigentümerwechsel – Vertragsnummer V123456789" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="Sehr geehrte Damen und Herren,&#10; &#10;hiermit teile ich Ihnen mit, dass ich mein Einfamilienhaus in der Hauptstraße 43, 30159 Hannover zum 01.04.2026.&#10; &#10;Ich bitte Sie, den bestehenden Wohngebäudeversicherungsvertrag (Vertragsnr. V123456789) entsprechend auf die neue Eigentümer umzuschreiben.&#10; &#10;Für Rückfragen stehe ich Ihnen gerne zur Verfügung.&#10; &#10;Mit freundlichen Grüßen&#10;John Doe" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1waftpa</bpmn:incoming>
      <bpmn:outgoing>Flow_0q5z114</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0jb8hom" name="Rückmeldung zu Nachfrage" zeebe:modelerTemplate="io.camunda.connectors.email.v1" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:documentation />
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:email:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="simple" target="authentication.type" />
          <zeebe:input source="{{secrets.E2E_SMTP_USERNAME}}" target="authentication.username" />
          <zeebe:input source="{{secrets.E2E_SMTP_PASSWORD}}" target="authentication.password" />
          <zeebe:input source="smtp" target="protocol" />
          <zeebe:input source="{{secrets.E2E_SMTP_SERVER}}" target="data.smtpConfig.smtpHost" />
          <zeebe:input source="{{secrets.E2E_SMTP_PORT}}" target="data.smtpConfig.smtpPort" />
          <zeebe:input source="NONE" target="data.smtpConfig.smtpCryptographicProtocol" />
          <zeebe:input source="sendEmailSmtp" target="data.smtpActionDiscriminator" />
          <zeebe:input source="{{secrets.E2E_SMTP_USERNAME}}" target="data.smtpAction.from" />
          <zeebe:input source="{{secrets.E2E_SMTP_USERNAME}}" target="data.smtpAction.to" />
          <zeebe:input source="RE: Eigentümerwechsel – Vertragsnummer V123456789" target="data.smtpAction.subject" />
          <zeebe:input source="PLAIN" target="data.smtpAction.contentType" />
          <zeebe:input source="Der Käufer ist Jane Doe, Nebenstraße 6 in 20146 Hamburg" target="data.smtpAction.body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="3" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.email.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1vq2738</bpmn:incoming>
      <bpmn:outgoing>Flow_0kdqqxt</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0kdqqxt" sourceRef="Activity_0jb8hom" targetRef="Event_0g7xivr" />
    <bpmn:sequenceFlow id="Flow_0q5z114" sourceRef="Activity_019gubg" targetRef="event_wait_for_feedback" />
