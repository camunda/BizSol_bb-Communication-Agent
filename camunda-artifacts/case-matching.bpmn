<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0egaanq" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="case-matching" isExecutable="true">
    <bpmn:scriptTask id="Task_CaseMatching" name="Use FEEL">
      <bpmn:extensionElements>
        <zeebe:script expression="=if contract_number != null then contract_number+&#34;/&#34;+customer_intent&#10;else if supportCase.communicationContext.channel = &#34;email&#34; then supportCase.communicationContext.emailAddress+&#34;/&#34;+customer_intent&#10;else if supportCase.communicationContext.channel = &#34;phone&#34; then supportCase.communicationContext.phoneNumber+&#34;/&#34;+customer_intent&#10;else supportCase.communicationContext.conversationId+&#34;/&#34;+customer_intent" resultVariable="correlationKey" />
        <zeebe:ioMapping>
          <zeebe:output source="=correlationKey" target="correlationKey" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0sqti1x</bpmn:incoming>
      <bpmn:outgoing>Flow_1knqafj</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1v9hvfy" sourceRef="StartEvent_1" targetRef="Gateway_1oud21o" />
    <bpmn:exclusiveGateway id="Gateway_1oud21o" name="Use FEEL expression?" default="Flow_1hi58vu">
      <bpmn:incoming>Flow_1v9hvfy</bpmn:incoming>
      <bpmn:outgoing>Flow_18flqnj</bpmn:outgoing>
      <bpmn:outgoing>Flow_1hi58vu</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_18flqnj" name="yes" sourceRef="Gateway_1oud21o" targetRef="Activity_0eq9kgt">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=(use_feel = true)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1hi58vu" name="no" sourceRef="Gateway_1oud21o" targetRef="Activity_14url9k" />
    <bpmn:endEvent id="Event_End">
      <bpmn:extensionElements />
      <bpmn:incoming>Flow_0wys4a2</bpmn:incoming>
      <bpmn:incoming>Flow_1knqafj</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0wys4a2" sourceRef="Activity_14url9k" targetRef="Event_End" />
    <bpmn:sequenceFlow id="Flow_1knqafj" sourceRef="Task_CaseMatching" targetRef="Event_End" />
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_1v9hvfy</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_14url9k" name="Use Worker">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="CaseMatching" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1hi58vu</bpmn:incoming>
      <bpmn:outgoing>Flow_0wys4a2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="Activity_0eq9kgt" name="Evaluate Intent">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="intent_matching" resultVariable="customer_intent" />
        <zeebe:ioMapping>
          <zeebe:input source="=supportCase.subject" target="subject" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_18flqnj</bpmn:incoming>
      <bpmn:outgoing>Flow_0pl0gjw</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_0pl0gjw" sourceRef="Activity_0eq9kgt" targetRef="Activity_0gvu0uz" />
    <bpmn:scriptTask id="Activity_0gvu0uz" name="Extract Contract">
      <bpmn:extensionElements>
        <zeebe:script expression="=  if supportCase.subject != null and matches(supportCase.subject, &#34;.*\\bV\\d{9}\\b.*&#34;)&#10;  then replace(supportCase.subject, &#34;.*?(\\bV\\d{9}\\b).*&#34;, &#34;$1&#34;)&#10;  else null" resultVariable="contract_number" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0pl0gjw</bpmn:incoming>
      <bpmn:outgoing>Flow_0sqti1x</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0sqti1x" sourceRef="Activity_0gvu0uz" targetRef="Task_CaseMatching" />
    <bpmn:textAnnotation id="TextAnnotation_0p54tkg">
      <bpmn:text>Accumulate correlationKey based on contract and intent. Use fallback in case of missing values.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0eoaqmk" associationDirection="None" sourceRef="Task_CaseMatching" targetRef="TextAnnotation_0p54tkg" />
    <bpmn:textAnnotation id="TextAnnotation_0ns7166">
      <bpmn:text>Try to match the incoming message to available categories. This is needed to support multiple conversations per person 1:n.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0eqsb7u" associationDirection="None" sourceRef="Activity_0eq9kgt" targetRef="TextAnnotation_0ns7166" />
    <bpmn:textAnnotation id="TextAnnotation_1gx3ry1">
      <bpmn:text>Try to extract a contract number from the incoming message to support n:1 communication. Multiple persons can communicate to the same issue.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_17yjwpw" associationDirection="None" sourceRef="Activity_0gvu0uz" targetRef="TextAnnotation_1gx3ry1" />
  </bpmn:process>
  <bpmn:message id="Message_3lngj06" name="UnmatchedCommunicationReceived" />
