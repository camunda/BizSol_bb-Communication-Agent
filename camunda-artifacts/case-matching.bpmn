<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0egaanq"
                  targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0"
                  modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
    <bpmn:process id="case-matching" isExecutable="true">
        <bpmn:startEvent id="StartEvent_1">
            <bpmn:outgoing>Flow_1v9hvfy</bpmn:outgoing>
            <bpmn:messageEventDefinition id="MessageEventDefinition_05g85w0" messageRef="Message_3lngj06"/>
        </bpmn:startEvent>
        <bpmn:endEvent id="Event_SendCustomerCommunicationReceived"
                       zeebe:modelerTemplate="io.camunda.connectors.message.end.v1" zeebe:modelerTemplateVersion="0"
                       zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
            <bpmn:extensionElements>
                <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3"/>
                <zeebe:ioMapping>
                    <zeebe:input source="CustomerCommunicationReceived" target="messageName"/>
                    <zeebe:input source="=correlationKey" target="correlationKey"/>
                    <zeebe:input source="={&#34;supportCase&#34;: supportCase }" target="variables"/>
                    <zeebe:input source="publish" target="correlationType.type"/>
                </zeebe:ioMapping>
                <zeebe:taskHeaders>
                    <zeebe:header key="elementTemplateVersion" value="0"/>
                    <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1"/>
                    <zeebe:header key="retryBackoff" value="PT0S"/>
                </zeebe:taskHeaders>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_0kfwt3p</bpmn:incoming>
            <bpmn:messageEventDefinition id="MessageEventDefinition_1f048s1"/>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_0kfwt3p" sourceRef="Task_CaseMatching"
                           targetRef="Event_SendCustomerCommunicationReceived"/>
        <bpmn:scriptTask id="Task_CaseMatching" name="Match Case">
            <bpmn:extensionElements>
                <zeebe:script
                        expression="=if supportCase.communicationContext.channel = &#34;email&#34; then supportCase.communicationContext.emailAddress&#10;else if supportCase.communicationContext.channel = &#34;phone&#34; then supportCase.communicationContext.phoneNumber&#10;else supportCase.communicationContext.conversationId"
                        resultVariable="correlationKey"/>
                <zeebe:ioMapping>
                    <zeebe:output source="=correlationKey" target="correlationKey"/>
                </zeebe:ioMapping>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_1v9hvfy</bpmn:incoming>
            <bpmn:outgoing>Flow_0kfwt3p</bpmn:outgoing>
        </bpmn:scriptTask>
        <bpmn:sequenceFlow id="Flow_1v9hvfy" sourceRef="StartEvent_1" targetRef="Task_CaseMatching"/>
        <bpmn:textAnnotation id="TextAnnotation_0p54tkg">
            <bpmn:text>Assign supportCase.correlationKey</bpmn:text>
        </bpmn:textAnnotation>
        <bpmn:association id="Association_0eoaqmk" associationDirection="None" sourceRef="Task_CaseMatching"
                          targetRef="TextAnnotation_0p54tkg"/>
    </bpmn:process>
    <bpmn:message id="Message_3lngj06" name="UnmatchedCommunicationReceived"/>
    <bpmndi:BPMNDiagram id="BPMNDiagram_1">
        <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="case-matching">
            <bpmndi:BPMNShape id="Event_0ccv1wt_di" bpmnElement="StartEvent_1">
                <dc:Bounds x="182" y="222" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Event_10n1558_di" bpmnElement="Event_SendCustomerCommunicationReceived">
                <dc:Bounds x="672" y="222" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Activity_13vrd2u_di" bpmnElement="Task_CaseMatching">
                <dc:Bounds x="410" y="200" width="100" height="80"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="TextAnnotation_0p54tkg_di" bpmnElement="TextAnnotation_0p54tkg">
                <dc:Bounds x="580" y="120" width="230" height="48"/>
                <bpmndi:BPMNLabel/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNEdge id="Flow_0kfwt3p_di" bpmnElement="Flow_0kfwt3p">
                <di:waypoint x="510" y="240"/>
                <di:waypoint x="672" y="240"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="Flow_1v9hvfy_di" bpmnElement="Flow_1v9hvfy">
                <di:waypoint x="218" y="240"/>
                <di:waypoint x="410" y="240"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="Association_0eoaqmk_di" bpmnElement="Association_0eoaqmk">
                <di:waypoint x="510" y="209"/>
                <di:waypoint x="580" y="166"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</bpmn:definitions>
