<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0d9altk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="business-agent-translator" isExecutable="true">
    <bpmn:startEvent id="Event_01wko7j" name="Customer message received via communication agent">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=customerMessage" target="customerMessage" />
          <zeebe:output source="=customerContext" target="customerContext" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0t3eedz</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1e3rubz" messageRef="Message_34hfs6a" />
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="Activity_1epfygy" name="Translator Agent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="eu-west-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{ secrets.AWS_BEDROCK_ACCESS_KEY }}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{ secrets.AWS_BEDROCK_SECRET_KEY }}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="global.anthropic.claude-sonnet-4-5-20250929-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a very specialized **Translator Agent**. You will get messages from a customer asking for certain translation problems to be solved. You should use your own domain knowledge and the tools provided to you to resolve these problems.&#10;&#10;You may send messages back to the customer to provide your answer or ask for clarifications and further information if necessary. In this case, make sure that you always wait for a reply message from the customer via the &#39;Wait for next message&#39; tool. Be communicative and ask the customer whether there are any other translation issues they would like to solve before finishing.&#10;&#10;If tools are provided, you should prefer them instead of guessing an answer. You can call the same tool multiple times by providing different input values. Don&#39;t guess any tools which were not explicitly configured.&#10;&#10;Wrap minimal, inspectable reasoning in *exactly* this XML template:&#10;&#10;&#60;thinking&#62;&#10;&#60;context&#62;…briefly state the customer’s need and current state…&#60;/context&#62;&#10;&#60;reflection&#62;…list candidate tools, justify which you will call next and why…&#60;/reflection&#62;&#10;&#60;/thinking&#62;&#10;&#10;Reveal **no** additional private reasoning outside these tags.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=customerMessage" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=100" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0t3eedz</bpmn:incoming>
      <bpmn:outgoing>Flow_1v14l6q</bpmn:outgoing>
      <bpmn:sendTask id="Activity_Message-customer" name="Reply to customer via communication agent" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Use this activity to reply to a customer. The tool will not directly return a result, but you may have to wait for a reply. The main purpose of this tool is to reply to the customers who are involved in this particular case. You do not need to know any details of the customer to use this tool.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="message-business-agent-to-communication-agent" target="messageName" />
            <zeebe:input source="=customerContext.id" target="correlationKey" />
            <zeebe:input source="={&#10;  businessAgentType: &#34;Translator Agent&#34;,&#10;  businessAgentReply: fromAi(toolCall.businessAgentReply, &#34;Your reply to the customer&#34;)&#10;}" target="variables" />
            <zeebe:input source="publish" target="correlationType.type" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="0" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
            <zeebe:header key="resultExpression" value="={&#10;  toolCallResult: &#34;Reply message sent&#34;&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:sendTask>
      <bpmn:eventBasedGateway id="Tool_Wait-for-next-message" name="Wait for next message">
        <bpmn:outgoing>Flow_0r3gwpk</bpmn:outgoing>
        <bpmn:outgoing>Flow_1r3z0uk</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_1g1uzw3" name="Subsequent customer message received">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  customerMessage: customerMessage,&#10;  customerContext: customerContext&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0r3gwpk</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_0al6lp0" messageRef="Message_34hfs6a" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_0r3gwpk" sourceRef="Tool_Wait-for-next-message" targetRef="Event_1g1uzw3" />
      <bpmn:intermediateCatchEvent id="Event_1356pri" name="Timeout after 24 hours">
        <bpmn:incoming>Flow_1r3z0uk</bpmn:incoming>
        <bpmn:timerEventDefinition id="TimerEventDefinition_0y9y4yp">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1r3z0uk" sourceRef="Tool_Wait-for-next-message" targetRef="Event_1356pri" />
      <bpmn:task id="Activity_1tnljzh" name="Use tool">
        <bpmn:documentation>This is a dummy tool to illustrate to users what can be done within AI agents. Do not ever use this tool.</bpmn:documentation>
      </bpmn:task>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_0t3eedz" sourceRef="Event_01wko7j" targetRef="Activity_1epfygy" />
    <bpmn:endEvent id="Event_1e2kqoj" name="Agent finished" zeebe:modelerTemplate="io.camunda.connectors.message.end.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-business-agent-to-communication-agent-termination" target="messageName" />
          <zeebe:input source="=customerContext.id" target="correlationKey" />
          <zeebe:input source="={&#10;  businessAgentType: &#34;Translation Agent&#34;&#10;}" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1v14l6q</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0no9oip" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1v14l6q" sourceRef="Activity_1epfygy" targetRef="Event_1e2kqoj" />
    <bpmn:textAnnotation id="TextAnnotation_0sjkqrb">
      <bpmn:text>The "Translator Agent" is an example of a complex business agent that is in itself a potentially long-running agent with tools available. It can message back and forth with the communication agent to get further input from the customer, if required.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0p36885" associationDirection="None" sourceRef="Activity_1epfygy" targetRef="TextAnnotation_0sjkqrb" />
    <bpmn:textAnnotation id="TextAnnotation_15kdq8v">
      <bpmn:text>Add more tools to make your business agents more powerful depending on your needs</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_18hinaw" associationDirection="None" sourceRef="Activity_1tnljzh" targetRef="TextAnnotation_15kdq8v" />
  </bpmn:process>
  <bpmn:message id="Message_ChatMessage" name="chat-message" />
  <bpmn:message id="Message_3mdd6nm" name="message-communication-agent-to-business-agent-calculator">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=customerContext.id" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_1s2js0p" name="AgentFinished">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=&#34;dummy&#34;" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_15tipll" name="message-startBusinessAgentA" />
  <bpmn:message id="Message_11edjga" name="message-notifyBusinessAgentA">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=payloadStart.customerInfo.id + &#34;-AgentA&#34;" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_0mfbuns" name="message-agentMessageReceived">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=customerInfo.id" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:escalation id="Escalation_1j6tmm2" name="start-agent-b" escalationCode="start-agent-b" />
  <bpmn:signal id="Signal_1m1uv91" name="start-agent-b" />
  <bpmn:escalation id="Escalation_08n87hs" name="business-agent-b-reply" escalationCode="business-agent-b-reply" />
  <bpmn:message id="Message_34hfs6a" name="message-communication-agent-to-business-agent-translator">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=customerContext.id" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
