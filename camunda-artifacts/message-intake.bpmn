<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0d9altk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="message-intake" isExecutable="true">
    <bpmn:businessRuleTask id="Activity_FindCustomerContext" name="Find customer context">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=messageContext.channel + &#34;:&#34; + messageContext.from" target="lookupKey" />
        </zeebe:ioMapping>
        <zeebe:calledDecision decisionId="customer-database" resultVariable="customerContext" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0kliake</bpmn:incoming>
      <bpmn:outgoing>Flow_0fbmjga</bpmn:outgoing>
      <bpmn:property id="Property_0wuxgoh" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1srhckd">
        <bpmn:sourceRef>DataStoreReference_CustomerDatabase</bpmn:sourceRef>
        <bpmn:targetRef>Property_0wuxgoh</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="Gateway_CustomerFound" name="Customer found?" default="Flow_02qf9ba">
      <bpmn:incoming>Flow_0fbmjga</bpmn:incoming>
      <bpmn:outgoing>Flow_02qf9ba</bpmn:outgoing>
      <bpmn:outgoing>Flow_0qkfpjz</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0fbmjga" sourceRef="Activity_FindCustomerContext" targetRef="Gateway_CustomerFound" />
    <bpmn:sequenceFlow id="Flow_02qf9ba" name="No" sourceRef="Gateway_CustomerFound" targetRef="Event_CustomerUnknown" />
    <bpmn:endEvent id="Event_CustomerUnknown" name="Customer is unknown">
      <bpmn:incoming>Flow_02qf9ba</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0xw65xs" errorRef="Error_0ubdfmd" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0qkfpjz" name="Yes" sourceRef="Gateway_CustomerFound" targetRef="Event_PropagateMessageToCommAgent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=(customerContext.id != null)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_MergeIncomingMessages">
      <bpmn:incoming>Flow_0x6ag44</bpmn:incoming>
      <bpmn:incoming>Flow_1ekrcjb</bpmn:incoming>
      <bpmn:incoming>Flow_0r3l9zy</bpmn:incoming>
      <bpmn:incoming>Flow_0vlyq4h</bpmn:incoming>
      <bpmn:outgoing>Flow_06hm0ui</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:startEvent id="Event_GenericMessageFromCustomer" name="Generic message from customer received">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_1s22j9e</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0igtuud" messageRef="Message_3hgg72t" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1s22j9e" sourceRef="Event_GenericMessageFromCustomer" targetRef="Activity_ExtractMessageContextFromGenericMessage" />
    <bpmn:sequenceFlow id="Flow_06hm0ui" sourceRef="Gateway_MergeIncomingMessages" targetRef="Gateway_MessageContextComplete" />
    <bpmn:dataStoreReference id="DataStoreReference_CustomerDatabase" name="Customer database" />
    <bpmn:sequenceFlow id="Flow_0x6ag44" sourceRef="Activity_ExtractMessageContextFromSms" targetRef="Gateway_MergeIncomingMessages" />
    <bpmn:scriptTask id="Activity_ExtractMessageContextFromSms" name="Extract message context from SMS">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  channel: &#34;sms&#34;,&#10;  from: dummy_sms.request.body.From,&#10;  subject: &#34;&#34;,&#10;  message: dummy_sms.request.body.Body&#10;}" resultVariable="messageContext" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_00g6tn6</bpmn:incoming>
      <bpmn:outgoing>Flow_0x6ag44</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_ExtractMessageContextFromEmail" name="Extract message context from Email">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  channel: &#34;email&#34;,&#10;  from: dummy_email.fromAddress,&#10;  subject: dummy_email.subject,&#10;  message: dummy_email.plainTextBody&#10;}" resultVariable="messageContext" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0odl2gn</bpmn:incoming>
      <bpmn:outgoing>Flow_1ekrcjb</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1ekrcjb" sourceRef="Activity_ExtractMessageContextFromEmail" targetRef="Gateway_MergeIncomingMessages" />
    <bpmn:scriptTask id="Activity_ExtractMessageContextFromGenericMessage" name="Extract message context from message">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  channel: testChannel,&#10;  from: testFrom,&#10;  subject: testSubject,&#10;  message: testMessage&#10;}" resultVariable="messageContext" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1s22j9e</bpmn:incoming>
      <bpmn:outgoing>Flow_0r3l9zy</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0r3l9zy" sourceRef="Activity_ExtractMessageContextFromGenericMessage" targetRef="Gateway_MergeIncomingMessages" />
    <bpmn:exclusiveGateway id="Gateway_MessageContextComplete" name="Message context complete?" default="Flow_1olva75">
      <bpmn:incoming>Flow_06hm0ui</bpmn:incoming>
      <bpmn:outgoing>Flow_045luqa</bpmn:outgoing>
      <bpmn:outgoing>Flow_1olva75</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_045luqa" name="Yes" sourceRef="Gateway_MessageContextComplete" targetRef="Activity_RunAiFirewall">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=messageContext.channel != null and
not(is blank(messageContext.channel)) and
messageContext.from != null and
not(is blank(messageContext.from)) and
messageContext.subject != null and
messageContext.message != null and
not(is blank(messageContext.from))</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1olva75" name="No" sourceRef="Gateway_MessageContextComplete" targetRef="Event_MessageContextIncomplete" />
    <bpmn:endEvent id="Event_MessageContextIncomplete" name="Message context is incomplete">
      <bpmn:incoming>Flow_1olva75</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1828u5o" errorRef="Error_1coubrc" />
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_PropagateMessageToCommAgent" name="Propagate message to communication agent" zeebe:modelerTemplate="io.camunda.connectors.message.end.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-intake-to-communication-agent" target="messageName" />
          <zeebe:input source="=customerContext.id" target="correlationKey" />
          <zeebe:input source="={&#10;  customerContext: customerContext,&#10;  messageContext: messageContext&#10;}" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0qkfpjz</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_023w9db" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0kliake" sourceRef="Activity_RunAiFirewall" targetRef="Activity_FindCustomerContext" />
    <bpmn:endEvent id="Event_MessageBlockedByAiFirewall" name="Message blocked by AI firewall">
      <bpmn:incoming>Flow_0hzpji4</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1o5viv1" errorRef="Error_1qika3r" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0hzpji4" sourceRef="Event_EscalationFromAiFirewall" targetRef="Event_MessageBlockedByAiFirewall" />
    <bpmn:scriptTask id="Activity_RunAiFirewall" name="Run AI firewall">
      <bpmn:extensionElements>
        <zeebe:script expression="=&#34;AI firewall executed&#34;" resultVariable="dummy_ai-firewall-result" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_045luqa</bpmn:incoming>
      <bpmn:outgoing>Flow_0kliake</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:boundaryEvent id="Event_EscalationFromAiFirewall" name="AI firewall failed or message blocked" attachedToRef="Activity_RunAiFirewall">
      <bpmn:outgoing>Flow_0hzpji4</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1kq93mb" />
    </bpmn:boundaryEvent>
    <bpmn:startEvent id="Event_EmailFromCustomer" name="Email from customer received">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_0odl2gn</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0ulhp56" messageRef="Message_3eaqmdq" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0odl2gn" sourceRef="Event_EmailFromCustomer" targetRef="Activity_ExtractMessageContextFromEmail" />
    <bpmn:startEvent id="Event_SmsFromCustomer" name="SMS from customer received">
      <bpmn:outgoing>Flow_00g6tn6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1lzqn2i" messageRef="Message_104tvdo" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_00g6tn6" sourceRef="Event_SmsFromCustomer" targetRef="Activity_ExtractMessageContextFromSms" />
    <bpmn:startEvent id="Event_ChatFromCustomer" name="Chat from customer received">
      <bpmn:outgoing>Flow_0oehmcv</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0e6curw" messageRef="Message_03nbod2" />
    </bpmn:startEvent>
    <bpmn:scriptTask id="Activity_ExtractMessageContextFromChat" name="Extract message context from chat">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  channel: &#34;chat&#34;,&#10;  from: dummy_chat.from,&#10;  subject: &#34;&#34;,&#10;  message: dummy_chat.message&#10;}" resultVariable="messageContext" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0oehmcv</bpmn:incoming>
      <bpmn:outgoing>Flow_0vlyq4h</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_0oehmcv" sourceRef="Event_ChatFromCustomer" targetRef="Activity_ExtractMessageContextFromChat" />
    <bpmn:sequenceFlow id="Flow_0vlyq4h" sourceRef="Activity_ExtractMessageContextFromChat" targetRef="Gateway_MergeIncomingMessages" />
    <bpmn:group id="Group_1gexwym" categoryValueRef="CategoryValue_1dr13oj" />
    <bpmn:textAnnotation id="TextAnnotation_1fjxz8m">
      <bpmn:text>Match the incoming message to a unique customer record in your system (the customer context for this message)

This will usually be done using service tasks and custom jobs or direct database access (e.g., SQL connector)

The output must be a unique record identifier for the customer as well as contact details for all your required output channels (e.g., email address, phone number, etc.).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0n4u9c3" associationDirection="None" sourceRef="Activity_FindCustomerContext" targetRef="TextAnnotation_1fjxz8m" />
    <bpmn:textAnnotation id="TextAnnotation_1lukjyb">
      <bpmn:text>Secure your system by running all incoming messages against an AI firewall.

Check the Camunda marketplace for a sample building block to swap in as a call activity:

https://marketplace.camunda.com/en-US/apps/XXXXXX/ai-firewall-agent</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_10oc60f" associationDirection="None" sourceRef="Activity_RunAiFirewall" targetRef="TextAnnotation_1lukjyb" />
    <bpmn:textAnnotation id="TextAnnotation_0yjr0oy">
      <bpmn:text>Add your own input channels via custom connectors, e.g., Email or SMS via webhooks and external services.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_01ila69" associationDirection="None" sourceRef="Group_1gexwym" targetRef="TextAnnotation_0yjr0oy" />
  </bpmn:process>
