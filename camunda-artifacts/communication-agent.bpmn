  </bpmn:message>
  <bpmn:message id="Message_1r1v4qd" name="WhatsApp2" />
  <bpmn:message id="Message_2obe48c" name="CustomerCommunicationReceived">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=supportCase.communicationContext.emailAddress" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_29lh69a" name="CustomerCommunicationRequired">
    <bpmn:extensionElements>
