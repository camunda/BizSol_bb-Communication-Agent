  </bpmn:message>
  <bpmn:message id="Message_0tibq0q" name="AgentFinished">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=supportCase.communicationContext.emailAddress" />
    </bpmn:extensionElements>
  </bpmn:message>
