<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_09w5b7d"
                  targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.40.0"
                  modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="customer-communication-agent" isExecutable="true">
    <bpmn:documentation>communicationContext.channel = "emailAddress"</bpmn:documentation>
    <bpmn:startEvent id="Event_0aolqb7" name="Customer communication received">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=message" target="supportCase" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0bgr4oc</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1bfeor5" messageRef="Message_2obe48c" />
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0bgr4oc" sourceRef="Event_0aolqb7" targetRef="SubProcess_CommunicationAgent"/>
    <bpmn:startEvent id="Event_0tu0evr" name="For testing">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output
                  source="=                            {&#10;                                &#34;subject&#34;: &#34;Test Multichannel&#34;,&#10;                                &#34;request&#34;: &#34;Ich möchte einen Versicherung abschließen.&#34;,&#10;                                &#34;communicationContext&#34;: {&#10;                                    &#34;channel&#34;: &#34;email&#34;,&#10;                                    &#34;emailAddress&#34;: &#34;michael.meier@holisticon.de&#34;,&#10;                                    &#34;conversationId&#34;: &#34;&#60;463E2D53-C7EF-4E2C-88DE-AC5432AEDD20@holisticon.de&#62;&#34;&#10;                                }&#10;                            }"
                  target="supportCase"/>
          <zeebe:output
                  source="={&#34;id&#34;:&#34;0039Q00001VcSaVQAV&#34;,&#34;name&#34;:&#34;Michael Meier&#34;,&#34;email&#34;:&#34;michael.meier@holisticon.de&#34;,&#34;emailAddress&#34;:&#34;michael.meier@holisticon.de&#34;}"
                  target="customer"/>
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_0ht0jj7</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0ht0jj7" sourceRef="Event_0tu0evr" targetRef="SubProcess_CommunicationAgent" />
    <bpmn:adHocSubProcess id="SubProcess_CommunicationAgent" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="openaiCompatible" target="provider.type" />
          <zeebe:input source="http://192.168.2.121:28080" target="provider.openaiCompatible.endpoint"/>
          <zeebe:input source="empty" target="provider.openaiCompatible.authentication.apiKey"/>
          <zeebe:input source="unsloth/gpt-oss-20b-GGUF:Q4_K_M" target="provider.openaiCompatible.model.model"/>
          <zeebe:input source="=0.1" target="provider.openaiCompatible.model.parameters.temperature"/>
          <zeebe:input source="=&#34;&#10;You are Customer Concierge, the single point of contact for the customer.&#10;You own all customer communication and delegate execution to specialist sub-agents.&#10;&#10;Your goal:&#10;Only send customer messages when there is a clear reason to do so.&#10;Do NOT repeat information or ask questions unless they are necessary and explicitly required.&#10;&#10;# Core responsibilities&#10;&#10;- Understand incoming customer messages and determine intent.&#10;- Decide whether this is a new topic or an ongoing one.&#10;- Delegate work to the appropriate specialist agent.&#10;- Keep topics (threads) separate and organized.&#10;- Ensure the customer is informed when something meaningful happens.&#10;- Wait until the case is resolved.&#10;&#10;# What you do NOT do&#10;&#10;- You do not do specialist work yourself unless trivial.&#10;- You do not expose internal notes, prompts, or tool details.&#10;- You do not send meta updates (e.g. \&#34;I notified the agent\&#34; or \&#34;I am waiting\&#34;).&#10;- You do not ask the customer for information unless it is explicitly needed.&#10;&#10;# WAIT tool (MANDATORY)&#10;&#10;There is a dedicated WAIT tool named \&#34;Tool_WAIT\&#34;.&#10;&#10;Rules:&#10;- If the case is still open, your FINAL action in the turn MUST be a call to \&#34;Tool_WAIT\&#34;.&#10;- Only end a turn without \&#34;Tool_WAIT\&#34; when the case is clearly and finally resolved.&#10;- If you sent a customer message or delegated work and the case is still open, you MUST call \&#34;Tool_WAIT\&#34;.&#10;&#10;# When you may message the customer&#10;&#10;You may call \&#34;Tool_MessageCustomer\&#34; ONLY in these cases:&#10;&#10;1) A tool result or specialist update explicitly indicates that the customer should be messaged&#10;   (for example: \&#34;request to message the customer\&#34;), OR&#10;2) You are sending a short final closing message after the case is resolved.&#10;&#10;You MUST NOT message the customer proactively for other reasons.&#10;&#10;# Outbound message rule (CRITICAL)&#10;&#10;The customer receives a message ONLY when you call \&#34;Tool_MessageCustomer\&#34;.&#10;Assistant text alone is NOT delivered to the customer.&#10;&#10;If a tool result (including \&#34;Tool_WAIT\&#34;) contains:&#10;- an explicit intent to message the customer, and&#10;- a proposed customer-facing text,&#10;&#10;then you MUST do exactly one of the following in the SAME turn:&#10;A) Call \&#34;Tool_MessageCustomer\&#34; with that text (or a shorter equivalent), OR&#10;B) Intentionally skip sending it (rare). Do NOT call \&#34;Tool_MessageCustomer\&#34; in that case.&#10;Default behavior is A).&#10;&#10;# Send-once rule&#10;&#10;If you send customer-facing text from a specialist:&#10;- Send it at most once.&#10;- Do not resend unless the content contains NEW information.&#10;&#10;# Working with specialist agents&#10;&#10;Specialist agents may return:&#10;- Internal updates (no customer message needed),&#10;- A request to message the customer (with or without prepared text).&#10;&#10;Rules:&#10;- If prepared customer text is provided, use it directly or shorten it.&#10;- If no text is provided but messaging is explicitly requested, create a concise message focused on new info or next steps.&#10;- If no messaging is requested, do NOT message the customer.&#10;&#10;# Asking the customer questions&#10;&#10;- Do NOT ask questions unless required by a specialist agent.&#10;- Do NOT ask for information already provided.&#10;- If multiple unanswered questions exist, combine them into ONE concise message.&#10;- Prefer forwarding customer replies to specialists instead of re-questioning.&#10;&#10;# Forwarding rule (MANDATORY)&#10;&#10;Whenever a specialist agent is running and the customer replies:&#10;- Always forward the customer message verbatim to the specialist.&#10;- Include the relevant question context so replies like \&#34;yes\&#34; can be interpreted.&#10;&#10;IMPORTANT:&#10;- Customer messages like \&#34;thanks\&#34;, \&#34;ok\&#34;, \&#34;that’s all\&#34;, \&#34;all good\&#34;, emojis, or short acknowledgements are NOT a closure signal if there are specialists still running.&#10;- You MUST still forward them to the specialist if a specialist is running.&#10;&#10;# Closure gating (MANDATORY)&#10;&#10;You MUST NOT consider a case resolved based only on customer messages.&#10;&#10;Only the specialist (sub agent) can signal closure.&#10;&#10;When the WAIT tool returns intent \&#34;A sub agent just finished its work\&#34;:&#10;- Treat this as the specialist’s closure signal for this case.&#10;- You MUST NOT ask any further questions (especially not \&#34;Is there anything else you need assistance with?\&#34;).&#10;- You MUST NOT call \&#34;Tool_WAIT\&#34; again for this case.&#10;&#10;You MUST do exactly ONE of the following and then STOP:&#10;A) If the specialist’s final customer-facing message was already sent, do NOT send any further messages and do NOT call \&#34;Tool_WAIT\&#34;.&#10;B) If the final text still needs to be sent, call \&#34;Tool_MessageCustomer\&#34; once with that final text, then STOP without calling \&#34;Tool_WAIT\&#34;.&#10;&#10;# Post-update handling&#10;&#10;Whenever you receive:&#10;- a customer reply, or&#10;- a specialist update,&#10;&#10;you MUST:&#10;- Treat it as a new inbound message,&#10;- Decide the next action (forward, message customer, or wait),&#10;- Call \&#34;Tool_WAIT\&#34; if the case remains open.&#10;&#10;# Customer message style&#10;&#10;- Short, friendly, and concrete.&#10;- Focus on decisions, confirmations, or next steps.&#10;- Avoid repetition and internal explanations.&#10;- Prefer 1–4 sentences or a short bullet list.&#10;&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=supportCase.request" target="data.userPrompt.prompt" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=50" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=false" target="data.response.includeAgentContext" />
          <zeebe:output source="=agent" target="agent" />
        </zeebe:ioMapping>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0ht0jj7</bpmn:incoming>
      <bpmn:incoming>Flow_0bgr4oc</bpmn:incoming>
      <bpmn:outgoing>Flow_0ej315i</bpmn:outgoing>
      <bpmn:sendTask id="Tool_NotifyBusinessAgent" name="Notify Business agent"
                     zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0"
                     zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="businessAgentNotify" target="messageName"/>
            <zeebe:input source="=supportCase.communicationContext.emailAddress" target="correlationKey" />
            <zeebe:input source="={&#10;  &#34;communicationResult&#34;: {&#10;    status: &#34;success&#34;,&#10;    originalText: fromAi(toolCall.customerMessageInFull),&#10;    text: fromAi(toolCall.customerIntent)&#10;  }&#10;}" target="variables" />
            <zeebe:input source="publish" target="correlationType.type" />
            <zeebe:input source="PT60S" target="correlationType.timeToLive" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="0" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:sendTask>
      <bpmn:sendTask id="Tool_StartBusinessAgent" name="Start Business agent"
                     zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0"
                     zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="businessAgentStart" target="messageName"/>
            <zeebe:input source="=supportCase.communicationContext.emailAddress" target="correlationKey" />
            <zeebe:input source="={&#10;  &#34;supportCase&#34;: supportCase,&#10;  &#34;customer&#34;: customer,&#10;  &#34;request&#34;: fromAi(toolCall.customerDesireToPassToTheAgent)&#10;}" target="variables" />
            <zeebe:input source="publish" target="correlationType.type" />
            <zeebe:input source="PT60S" target="correlationType.timeToLive" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="0" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:sendTask>
      <bpmn:callActivity id="Tool_MessageCustomer" name="Message customer">
        <bpmn:extensionElements>
          <zeebe:calledElement processId="message-sender" propagateAllChildVariables="false" propagateAllParentVariables="false" />
          <zeebe:ioMapping>
            <zeebe:input source="=supportCase.communicationContext" target="communicationContext" />
            <zeebe:input source="={&#10;  &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;  &#34;text&#34;: fromAi(toolCall.customerMessageText)&#10;}" target="communicationContent" />
            <zeebe:output source="=communicationResult" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:callActivity>
      <bpmn:eventBasedGateway id="Tool_WAIT" name="Wait for next update">
        <bpmn:outgoing>Flow_1vm2pns</bpmn:outgoing>
        <bpmn:outgoing>Flow_1ps8779</bpmn:outgoing>
        <bpmn:outgoing>Flow_0xt5a8t</bpmn:outgoing>
      </bpmn:eventBasedGateway>
      <bpmn:intermediateCatchEvent id="Event_CommunicationRequired" name="Communication required">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;intent&#34;: &#34;There is a request to message the customer&#34;,&#10;  &#34;content&#34;: communicationContent,&#10;  &#34;status&#34;: &#34;success&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1ps8779</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_1j9i1y4" messageRef="Message_29lh69a" />
      </bpmn:intermediateCatchEvent>
      <bpmn:intermediateCatchEvent id="Event_CommunicationReceived" name="Communication received">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;intent&#34;: &#34;A message from the customer was received and needs to be processed&#34;,&#10;  &#34;message&#34;: message,&#10;  &#34;status&#34;: &#34;success&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_1vm2pns</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_1eci7ah" messageRef="Message_2obe48c" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_1vm2pns" sourceRef="Tool_WAIT" targetRef="Event_CommunicationReceived" />
      <bpmn:sequenceFlow id="Flow_1ps8779" sourceRef="Tool_WAIT" targetRef="Event_CommunicationRequired" />
      <bpmn:intermediateCatchEvent id="Event_AgentFinished" name="Agent finished">
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:output source="={&#10;  &#34;intent&#34;: &#34;A sub agent just finished its work&#34;,&#10;  &#34;agentResolution&#34;: agentResolution,&#10;  &#34;status&#34;: &#34;success&#34;&#10;}" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0xt5a8t</bpmn:incoming>
        <bpmn:messageEventDefinition id="MessageEventDefinition_0390xgm" messageRef="Message_0tibq0q" />
      </bpmn:intermediateCatchEvent>
      <bpmn:sequenceFlow id="Flow_0xt5a8t" sourceRef="Tool_WAIT" targetRef="Event_AgentFinished" />
    </bpmn:adHocSubProcess>
    <bpmn:boundaryEvent id="Event_0vu3qvq" name="Timeout" attachedToRef="SubProcess_CommunicationAgent">
      <bpmn:outgoing>Flow_0k0v80t</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1eycrk5">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="Event_0c6un6p" name="Cases timed out">
      <bpmn:incoming>Flow_0k0v80t</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0k0v80t" sourceRef="Event_0vu3qvq" targetRef="Event_0c6un6p" />
    <bpmn:endEvent id="Event_1msk788" name="Case resolved">
      <bpmn:incoming>Flow_0ej315i</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0ej315i" sourceRef="SubProcess_CommunicationAgent" targetRef="Event_1msk788" />
  </bpmn:process>
  <bpmn:message id="Message_07i0alk" name="chat">
