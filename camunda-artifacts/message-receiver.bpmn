        <dc:Bounds x="740" y="210" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1gdoluy_di" bpmnElement="Event_1gdoluy">
        <dc:Bounds x="932" y="232" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1ehxd7q_di" bpmnElement="Flow_1ehxd7q">
        <di:waypoint x="840" y="250" />
        <di:waypoint x="932" y="250" />
      </bpmndi:BPMNEdge>
