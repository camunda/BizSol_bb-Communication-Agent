<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0fzcjmg"
                  targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.40.0"
                  modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
    <bpmn:process id="business-agent" isExecutable="true">
        <bpmn:startEvent id="StartEvent_1" name="For testing">
            <bpmn:extensionElements>
                <zeebe:ioMapping>
                    <zeebe:output source="=&#34;4711&#34;" target="orderId"/>
                    <zeebe:output source="=&#34;will nicht&#34;" target="returnReason"/>
                    <zeebe:output
                            source="={&#10;  &#34;subject&#34;: &#34;WhatsApp Request&#34;,&#10;  &#34;request&#34;: &#34;Hi, I want to return a router I bought online.&#34;,&#10;  &#34;communicationContext&#34;: {&#10;        &#34;channel&#34; : &#34;whatsApp&#34;,&#10;        &#34;mobilePhone&#34;: &#34;+49123456789&#34;,&#10;        &#34;emailAddress&#34;: &#34;camunda.demo.bernd@gmail.com&#34;&#10;    }&#10;}"
                            target="supportCase"/>
                    <zeebe:output source="={&#10;  &#34;id&#34;: &#34;0039Q00001VsHMXQA3&#34;&#10;}" target="customer"/>
                </zeebe:ioMapping>
            </bpmn:extensionElements>
            <bpmn:outgoing>Flow_0eqjm89</bpmn:outgoing>
        </bpmn:startEvent>
        <bpmn:adHocSubProcess id="SubProcess_BusinessAgent"
                              zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1"
                              zeebe:modelerTemplateVersion="5"
                              zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
            <bpmn:extensionElements>
                <zeebe:ioMapping>
                    <zeebe:input source="bedrock" target="provider.type"/>
                    <zeebe:input source="{{secrets.IDP_AWS_REGION}}" target="provider.bedrock.region"/>
                    <zeebe:input source="credentials" target="provider.bedrock.authentication.type"/>
                    <zeebe:input source="{{secrets.CAMUNDAAGENT_AWS_ACCESS_KEY}}"
                                 target="provider.bedrock.authentication.accessKey"/>
                    <zeebe:input source="{{secrets.CAMUNDAAGENT_AWS_SECRET_KEY}}"
                                 target="provider.bedrock.authentication.secretKey"/>
                    <zeebe:input source="anthropic.claude-3-5-sonnet-20240620-v1:0"
                                 target="provider.bedrock.model.model"/>
                    <zeebe:input source="=5000" target="provider.bedrock.model.parameters.maxTokens"/>
                    <zeebe:input source="=0.2" target="provider.bedrock.model.parameters.temperature"/>
                    <zeebe:input source="=0.1" target="provider.bedrock.model.parameters.topP"/>
                    <zeebe:input
                            source="=&#34;You are an AI service agent for an insurance company. Your task is to help customers register the change of ownership of their property with their insurance company and rewrite the contract accordingly.&#10;&#10;## Context&#10;&#10;&#34; &#10;+ (if customer = null then&#10;     &#34;No current customer is available in the process variables.&#34;&#10;   else&#10;     &#34;Current customer (from process variable): &#34; + string(customer)&#10;  )&#10;+ &#34;&#10;&#10;## What you should do&#10;&#10;- Check if the name of the buyer/ the new owner if it is valid&#10;&#10;- When everything is valid rewrite the contract&#10;&#10;## Customer identification (hard rules)&#10;&#10;- Assume a process variable named \&#34;customer\&#34; may already be provided to you.&#10;- If \&#34;customer\&#34; is present and has a non-empty \&#34;id\&#34;, the customer is already identified:&#10;  - Use customer.id as the customerId for Magento tools.&#10;  - You MUST NOT ask the customer for email or mobile phone.&#10;  - You MUST NOT lookup the customer yourself.&#10;&#10;- Only if \&#34;customer\&#34; is missing OR customer.id is empty, use supportCase.communicationContext (email/mobile) to identify the customer via tools.&#10;&#10;- Only if neither \&#34;customer\&#34; nor supportCase.communicationContext provides usable identifiers, ask the customer for ONE identifier (email OR mobile).&#10;&#10;## Customer messaging and tools&#10;&#10;- Never output customer-facing text directly. Always use Tool_MessageCustomer for anything the customer should see.&#10;- Use tools as needed based on context. Do not follow a fixed script; decide the right tool calls from the situation.&#10;&#10;## Tool argument rules (hard rule)&#10;&#10;- When calling tools, you MUST always pass concrete values.&#10;- You MUST NOT use variable placeholders or expressions such as \&#34;${customer.id}\&#34;, \&#34;${...}\&#34;, or FEEL expressions in tool arguments.&#10;- If a value is available in the process context (for example customer.id), copy its concrete value into the tool argument.&#10;&#10;-always use german language.&#10;&#10;## When to wait vs end&#10;&#10;- If your last message to the customer contains a question or requires a reply, and it is NOT the final summary/closure described in the \&#34;Closing rule\&#34;, you MUST call Tool_WaitForMessage immediately after Tool_MessageCustomer.&#10;- If your message is informational or a final closing message as described in the \&#34;Closing rule\&#34;, you MUST NOT call Tool_WaitForMessage afterwards.&#10;&#10;## Closing rule (must prevent endless waiting)&#10;&#10;When the rewrite of the contract is completed and you have sent a final summary/closure to the customer:&#10;&#10;- The closing message MUST NOT contain a \&#34;?\&#34;.&#10;- Do NOT ask \&#34;Is there anything else...\&#34;, \&#34;Do you need anything else...\&#34;, or any other follow-up question.&#10;- Never combine the final summary/closure with a question. It must be a pure statement.&#10;- End with a statement like \&#34;If you need anything else in the future, feel free to reach out.\&#34;.&#10;- After that closing message (Tool_MessageCustomer), you MUST STOP and must NOT call Tool_WaitForMessage or any other tools.&#10;&#34;"
                            target="data.systemPrompt.prompt"/>
                    <zeebe:input source="=supportCase.request" target="data.userPrompt.prompt"/>
                    <zeebe:input target="agentContext"/>
                    <zeebe:input source="in-process" target="data.memory.storage.type"/>
                    <zeebe:input source="=20" target="data.memory.contextWindowSize"/>
                    <zeebe:input source="=50" target="data.limits.maxModelCalls"/>
                    <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior"/>
                    <zeebe:input source="text" target="data.response.format.type"/>
                    <zeebe:input source="=false" target="data.response.format.parseJson"/>
                    <zeebe:input source="=true" target="data.response.includeAssistantMessage"/>
                    <zeebe:input source="=false" target="data.response.includeAgentContext"/>
                    <zeebe:output source="=agent" target="agent"/>
                </zeebe:ioMapping>
                <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3"/>
                <zeebe:taskHeaders>
                    <zeebe:header key="elementTemplateVersion" value="5"/>
                    <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1"/>
                    <zeebe:header key="retryBackoff" value="PT0S"/>
                </zeebe:taskHeaders>
                <zeebe:adHoc outputCollection="toolCallResults"
                             outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}"/>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_1j9u2o1</bpmn:incoming>
            <bpmn:outgoing>Flow_1sm4gwc</bpmn:outgoing>
            <bpmn:sendTask id="Tool_MessageCustomer" name="Message customer"
                           zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1"
                           zeebe:modelerTemplateVersion="0"
                           zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
                <bpmn:extensionElements>
                    <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3"/>
                    <zeebe:ioMapping>
                        <zeebe:input source="CustomerCommunicationRequired" target="messageName"/>
                        <zeebe:input source="=supportCase.communicationContext.emailAddress" target="correlationKey"/>
                        <zeebe:input
                                source="={&#10;  &#34;communicationContent&#34;: {&#10;    &#34;subject&#34;: &#34;RE: &#34; + supportCase.subject,&#10;    &#34;text&#34;: fromAi(toolCall.messageToCustomer)&#10;  },&#10;  &#34;communicationContext&#34;: supportCase.communicationContext&#10;}"
                                target="variables"/>
                        <zeebe:input source="publish" target="correlationType.type"/>
                        <zeebe:input source="PT60S" target="correlationType.timeToLive"/>
                    </zeebe:ioMapping>
                    <zeebe:taskHeaders>
                        <zeebe:header key="elementTemplateVersion" value="0"/>
                        <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1"/>
                        <zeebe:header key="retryBackoff" value="PT0S"/>
                    </zeebe:taskHeaders>
                </bpmn:extensionElements>
            </bpmn:sendTask>
            <bpmn:receiveTask id="Tool_WaitForMessage" name="Wait for customer message" messageRef="Message_0rhp27p">
                <bpmn:extensionElements>
                    <zeebe:ioMapping>
                        <zeebe:output source="=communicationResult" target="toolCallResult"/>
                    </zeebe:ioMapping>
                </bpmn:extensionElements>
            </bpmn:receiveTask>
        </bpmn:adHocSubProcess>
        <bpmn:sequenceFlow id="Flow_0eqjm89" sourceRef="StartEvent_1" targetRef="Event_0nyk35b"/>
        <bpmn:endEvent id="Event_0il4izb">
            <bpmn:incoming>Flow_00z8ltx</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:sequenceFlow id="Flow_1sm4gwc" sourceRef="SubProcess_BusinessAgent" targetRef="Activity_1mrkke7"/>
        <bpmn:endEvent id="Event_0nyk35b">
            <bpmn:incoming>Flow_0eqjm89</bpmn:incoming>
        </bpmn:endEvent>
        <bpmn:startEvent id="Event_1xxrygt" name="Agent requested by customer message">
            <bpmn:outgoing>Flow_1j9u2o1</bpmn:outgoing>
            <bpmn:messageEventDefinition id="MessageEventDefinition_1j8muag" messageRef="Message_112pv0t"/>
        </bpmn:startEvent>
        <bpmn:sequenceFlow id="Flow_1j9u2o1" sourceRef="Event_1xxrygt" targetRef="SubProcess_BusinessAgent"/>
        <bpmn:sequenceFlow id="Flow_00z8ltx" sourceRef="Activity_1mrkke7" targetRef="Event_0il4izb"/>
        <bpmn:sendTask id="Activity_1mrkke7" name="Agent finished"
                       zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1"
                       zeebe:modelerTemplateVersion="0"
                       zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
            <bpmn:extensionElements>
                <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3"/>
                <zeebe:ioMapping>
                    <zeebe:input source="AgentFinished" target="messageName"/>
                    <zeebe:input source="=supportCase.communicationContext.emailAddress" target="correlationKey"/>
                    <zeebe:input source="= {&#10;  &#34;agentResolution&#34;: agent.responseMessage  &#10;}"
                                 target="variables"/>
                    <zeebe:input source="publish" target="correlationType.type"/>
                    <zeebe:input source="PT60S" target="correlationType.timeToLive"/>
                </zeebe:ioMapping>
                <zeebe:taskHeaders>
                    <zeebe:header key="elementTemplateVersion" value="0"/>
                    <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1"/>
                    <zeebe:header key="retryBackoff" value="PT0S"/>
                </zeebe:taskHeaders>
            </bpmn:extensionElements>
            <bpmn:incoming>Flow_1sm4gwc</bpmn:incoming>
            <bpmn:outgoing>Flow_00z8ltx</bpmn:outgoing>
        </bpmn:sendTask>
    </bpmn:process>
    <bpmn:message id="Message_1r1v4qd" name="WhatsApp2"/>
    <bpmn:message id="Message_0p7867v" name="ecommerceAgentStart"/>
    <bpmn:message id="Message_056rkja" name="ecommerceAgentNotify">
        <bpmn:extensionElements>
            <zeebe:subscription correlationKey="=supportCase.communicationContext.mobilePhone"/>
        </bpmn:extensionElements>
    </bpmn:message>
    <bpmn:message id="Message_0rhp27p" name="businessAgentNotify">
        <bpmn:extensionElements>
            <zeebe:subscription correlationKey="=supportCase.communicationContext.emailAddress"/>
        </bpmn:extensionElements>
    </bpmn:message>
    <bpmn:message id="Message_0ag1lgk" name="eigentumswechselAgentStart"/>
    <bpmn:message id="Message_112pv0t" name="businessAgentStart"/>
    <bpmndi:BPMNDiagram id="BPMNDiagram_1">
        <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="business-agent">
            <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
                <dc:Bounds x="432" y="262" width="36" height="36"/>
                <bpmndi:BPMNLabel>
                    <dc:Bounds x="424" y="305" width="52" height="14"/>
                </bpmndi:BPMNLabel>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Event_0nyk35b_di" bpmnElement="Event_0nyk35b">
                <dc:Bounds x="552" y="262" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Activity_1gvmxab_di" bpmnElement="SubProcess_BusinessAgent" isExpanded="true">
                <dc:Bounds x="320" y="80" width="390" height="140"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Activity_144xlhd_di" bpmnElement="Tool_MessageCustomer">
                <dc:Bounds x="350" y="120" width="100" height="80"/>
                <bpmndi:BPMNLabel/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Activity_0a19pyj_di" bpmnElement="Tool_WaitForMessage">
                <dc:Bounds x="470" y="120" width="100" height="80"/>
                <bpmndi:BPMNLabel/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Event_0il4izb_di" bpmnElement="Event_0il4izb">
                <dc:Bounds x="932" y="162" width="36" height="36"/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Event_0l4hj6x_di" bpmnElement="Event_1xxrygt">
                <dc:Bounds x="182" y="152" width="36" height="36"/>
                <bpmndi:BPMNLabel>
                    <dc:Bounds x="160" y="195" width="81" height="40"/>
                </bpmndi:BPMNLabel>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNShape id="Activity_1dwefqj_di" bpmnElement="Activity_1mrkke7">
                <dc:Bounds x="780" y="140" width="100" height="80"/>
                <bpmndi:BPMNLabel/>
            </bpmndi:BPMNShape>
            <bpmndi:BPMNEdge id="Flow_1sm4gwc_di" bpmnElement="Flow_1sm4gwc">
                <di:waypoint x="710" y="180"/>
                <di:waypoint x="780" y="180"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="Flow_1j9u2o1_di" bpmnElement="Flow_1j9u2o1">
                <di:waypoint x="218" y="170"/>
                <di:waypoint x="320" y="170"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="Flow_00z8ltx_di" bpmnElement="Flow_00z8ltx">
                <di:waypoint x="880" y="180"/>
                <di:waypoint x="932" y="180"/>
            </bpmndi:BPMNEdge>
            <bpmndi:BPMNEdge id="Flow_0eqjm89_di" bpmnElement="Flow_0eqjm89">
                <di:waypoint x="468" y="280"/>
                <di:waypoint x="552" y="280"/>
            </bpmndi:BPMNEdge>
        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>
</bpmn:definitions>