<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_0d9altk" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="business-agent-calculator" isExecutable="true">
    <bpmn:startEvent id="Event_01wko7j" name="Customer message received via communication agent">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=customerMessage" target="customerMessage" />
          <zeebe:output source="=customerContext" target="customerContext" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_1dqjnj0</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1e3rubz" messageRef="Message_0uc7blo" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0en1b1z" name="Solve math problem" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="eu-west-1" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{ secrets.AWS_BEDROCK_ACCESS_KEY }}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{ secrets.AWS_BEDROCK_SECRET_KEY }}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="global.anthropic.claude-sonnet-4-5-20250929-v1:0" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a very specialized **Calculator Agent**. You will get a single message from a customer asking for a certain mathematical problem or problems to be solved. You should use your own domain knowledge to solve these problems. Be concise in your reply and do not ramble.&#10;&#10;You can send back exactly one message to the customer, which should be your single text output. Do not add any fluff. If you cannot solve a problem, reply with a short explanation why it is not possible to provide a reply.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=customerMessage" target="data.userPrompt.prompt" />
          <zeebe:input source="=agent.context" target="data.context" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=10" target="data.limits.maxModelCalls" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=false" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="agent" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1dqjnj0</bpmn:incoming>
      <bpmn:outgoing>Flow_0e02y61</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_10p6dw5" name="Reply to customer via communication agent" zeebe:modelerTemplate="io.camunda.connectors.message.sendtask.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-business-agent-to-communication-agent" target="messageName" />
          <zeebe:input source="=customerContext.id" target="correlationKey" />
          <zeebe:input source="={&#10;  businessAgentType: &#34;Calculator Agent&#34;,&#10;  businessAgentReply: agent.responseText&#10;}" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0e02y61</bpmn:incoming>
      <bpmn:outgoing>Flow_1yjbwe6</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:sequenceFlow id="Flow_1yjbwe6" sourceRef="Activity_10p6dw5" targetRef="Event_0i9auxu" />
    <bpmn:sequenceFlow id="Flow_0e02y61" sourceRef="Activity_0en1b1z" targetRef="Activity_10p6dw5" />
    <bpmn:sequenceFlow id="Flow_1dqjnj0" sourceRef="Event_01wko7j" targetRef="Activity_0en1b1z" />
    <bpmn:endEvent id="Event_0i9auxu" name="Agent finished" zeebe:modelerTemplate="io.camunda.connectors.message.end.v1" zeebe:modelerTemplateVersion="0" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:sendMessage:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="message-business-agent-to-communication-agent-termination" target="messageName" />
          <zeebe:input source="=customerContext.id" target="correlationKey" />
          <zeebe:input source="={&#10;  businessAgentType: &#34;Calculator Agent&#34;&#10;}" target="variables" />
          <zeebe:input source="publish" target="correlationType.type" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="0" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.message.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1yjbwe6</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_0no9oip" />
    </bpmn:endEvent>
    <bpmn:textAnnotation id="TextAnnotation_1q2q8md">
      <bpmn:text>The "Calculator Agent" is a simple process that uses a more deterministic chain of tasks to illustrate that business agents can take any shape or form, even without AI tasks themselves for classical existing business processes to be used within the Communication Agent.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0bdfxlx" associationDirection="None" sourceRef="Event_01wko7j" targetRef="TextAnnotation_1q2q8md" />
  </bpmn:process>
  <bpmn:message id="Message_ChatMessage" name="chat-message" />
  <bpmn:message id="Message_3mdd6nm" name="message-communication-agent-to-business-agent-calculator">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=customerContext.id" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_1s2js0p" name="AgentFinished">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=&#34;dummy&#34;" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_15tipll" name="message-startBusinessAgentA" />
  <bpmn:message id="Message_11edjga" name="message-notifyBusinessAgentA">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=payloadStart.customerInfo.id + &#34;-AgentA&#34;" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_0mfbuns" name="message-agentMessageReceived">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=customerInfo.id" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:escalation id="Escalation_1j6tmm2" name="start-agent-b" escalationCode="start-agent-b" />
  <bpmn:signal id="Signal_1m1uv91" name="start-agent-b" />
  <bpmn:escalation id="Escalation_08n87hs" name="business-agent-b-reply" escalationCode="business-agent-b-reply" />
  <bpmn:message id="Message_0uc7blo" name="message-communication-agent-to-business-agent-calculator" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="business-agent-calculator">
      <bpmndi:BPMNShape id="Activity_17ix3qo_di" bpmnElement="Activity_0en1b1z">
        <dc:Bounds x="270" y="250" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BPMNShape_1wbf4d5" bpmnElement="Activity_10p6dw5">
        <dc:Bounds x="420" y="250" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0k9kuk5_di" bpmnElement="Event_01wko7j">
        <dc:Bounds x="182" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="156" y="315" width="90" height="66" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_09l7sf2_di" bpmnElement="Event_0i9auxu">
        <dc:Bounds x="572" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="555" y="315" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Association_0bdfxlx_di" bpmnElement="Association_0bdfxlx">
        <di:waypoint x="210" y="275" />
        <di:waypoint x="270" y="188" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1dqjnj0_di" bpmnElement="Flow_1dqjnj0">
        <di:waypoint x="218" y="290" />
        <di:waypoint x="270" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0e02y61_di" bpmnElement="Flow_0e02y61">
        <di:waypoint x="370" y="290" />
        <di:waypoint x="420" y="290" />
